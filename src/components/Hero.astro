---
// Hero section - Clean, professional design
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-content">
    <div class="greeting">Hello, I'm</div>
    <h1 class="hero-title">
      <span class="title-text">Outwardly Verse</span>
    </h1>
    <p class="hero-subtitle">Web Developer & Creative Explorer</p>
    <div class="hero-buttons">
      <a href={`${base}about/`} class="btn btn-primary">
        <span>About Me</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href="https://blog.frankwkd2026.dpdns.org/" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
        <span>Read Blog</span>
        <svg class="external-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
    </div>

    <!-- Tech stack badges -->
    <div class="tech-stack">
      <span class="tech-badge">C++</span>
      <span class="tech-badge">JavaScript</span>
      <span class="tech-badge">Rust</span>
      <span class="tech-badge">Python</span>
    </div>
  </div>

  <!-- Decorative elements -->
  <div class="hero-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>
</section>

<style>
  .hero {
    height: 100vh;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: var(--nav-height) 2rem 2rem;
  }

  .hero-content {
    text-align: center;
    z-index: 10;
    max-width: 800px;
    animation: fadeInUp 0.8s ease-out;
  }

  .greeting {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    color: #38BDF8;
    margin-bottom: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 9.5vw, 6.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
    word-break: break-word;
  }

  .title-text {
    position: relative;
    display: inline-block;
    background-image: 
      /* 1. 白色透明荧光笔划过光束 */
      linear-gradient(
        110deg,
        transparent 0%,
        transparent 38%,
        rgba(255, 255, 255, 0.85) 50%,
        transparent 62%,
        transparent 100%
      ),
      /* 2. 原基础三色炫彩渐变 */
      linear-gradient(135deg, #38BDF8 0%, #A855F7 50%, #EC4899 100%);
    background-size: 250% 100%, 200% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: 
      highlighterSweep 3.5s cubic-bezier(0.4, 0, 0.2, 1) infinite,
      gradientFlow 5s ease infinite,
      cleanBreathe 3s ease-in-out infinite;
  }

  /* 荧光笔划过特效：一次次平滑扫过文字 */
  @keyframes highlighterSweep {
    0% {
      background-position: -150% 0, 0% 50%;
    }
    40%, 100% {
      background-position: 150% 0, 100% 50%;
    }
  }

  /* 纯净呼吸闪烁：无外发光雾，干净利落 */
  @keyframes cleanBreathe {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.75;
      transform: scale(0.995);
    }
  }

  @keyframes gradientFlow {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-text);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .hero-description {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    color: var(--color-text-dim);
    margin-bottom: 2.5rem;
    line-height: 1.7;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    border-radius: 0.5rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
    border: none;
    box-shadow: 0 4px 14px var(--color-shadow);
  }

  .btn-primary:hover {
    background: #2563EB;
    box-shadow: 0 6px 20px var(--color-shadow);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--color-primary);
  }

  .btn-primary svg,
  .btn-secondary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg,
  .btn-secondary:hover svg {
    transform: translateX(3px);
  }

  .btn-primary svg,
  .btn-secondary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg,
  .btn-secondary:hover svg {
    transform: translateX(3px);
  }

  .tech-stack {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tech-badge {
    padding: 0.5rem 1rem;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    font-size: 0.875rem;
    color: var(--color-text-dim);
    transition: all 0.2s ease;
  }

  .tech-badge:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* Decorative glows */
  .hero-decoration {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
  }

  .glow-1 {
    width: 400px;
    height: 400px;
    background: var(--color-primary);
    top: 10%;
    left: 10%;
    animation: float 8s ease-in-out infinite;
  }

  .glow-2 {
    width: 300px;
    height: 300px;
    background: var(--color-accent-purple);
    bottom: 20%;
    right: 10%;
    animation: float 6s ease-in-out infinite reverse;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(20px, -20px);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .title-text {
      animation: none;
    }
    .glow-1, .glow-2 {
      animation: none;
    }
    .hero-content {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: calc(var(--nav-height) + 1.5rem) 1.25rem 2rem;
    }

    .greeting {
      font-size: 1rem;
      letter-spacing: 0.18em;
    }

    .hero-subtitle {
      font-size: 1.1rem;
      margin-bottom: 1.25rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .btn {
      width: 100%;
      max-width: 260px;
      justify-content: center;
      padding: 0.75rem 1.5rem;
    }

    .tech-stack {
      gap: 0.5rem;
    }

    .tech-badge {
      font-size: 0.8rem;
      padding: 0.35rem 0.85rem;
    }
  }
</style>
