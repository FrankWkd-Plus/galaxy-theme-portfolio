---
// Navigation component - Floating navbar with Theme Switcher & SVG icons
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
// BASE_URLを除いたパスで比較
const relativePath = currentPath.replace(base.slice(0, -1), '') || '/';
---

<nav class="nav">
  <div class="nav-container">
    <div class="nav-left">
      <a href={base} class="logo">Outwardly Verse</a>
      <a href="https://github.com/FrankWkd-Plus" target="_blank" rel="noopener noreferrer" class="github-link" aria-label="GitHub Profile">
        <svg class="github-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>

    <div class="nav-links">
      <a href={base} class:list={['nav-link', { active: relativePath === '/' }]}>
        Home
      </a>
      <a href="https://blog.frankwkd2026.dpdns.org/" target="_blank" rel="noopener noreferrer" class="nav-link nav-external">
        <span>Blog</span>
        <svg class="external-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
      <a href="https://github.com/FrankWkd-Plus?tab=repositories" target="_blank" rel="noopener noreferrer" class="nav-link nav-external">
        <span>Projects</span>
        <svg class="external-icon" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
      <a href={`${base}about/`} class:list={['nav-link', { active: relativePath.startsWith('/about') }]}>
        About
      </a>

      <!-- 🧪 Solid Labs Icon Theme Switcher (No border, no background) -->
      <div class="theme-switcher-wrapper">
        <button class="theme-btn" id="theme-btn" aria-label="Toggle Theme Presets">
          <svg class="flask-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6 22h12a2 2 0 0 0 1.73-3L14 9.6V4h1a1 1 0 1 0 0-2H9a1 1 0 0 0 0 2h1v5.6L4.27 19A2 2 0 0 0 6 22z"/>
          </svg>
        </button>
        <div class="theme-menu" id="theme-menu">
          <button class="theme-option" data-theme-val="default">
            <span class="dot dot-default"></span>
            <span>Default Abyss</span>
          </button>
          <button class="theme-option" data-theme-val="cyberpunk">
            <span class="dot dot-cyberpunk"></span>
            <span>Cyberpunk Emerald</span>
          </button>
          <button class="theme-option" data-theme-val="aurora">
            <span class="dot dot-aurora"></span>
            <span>Nordic Aurora</span>
          </button>
          <button class="theme-option" data-theme-val="amber">
            <span class="dot dot-amber"></span>
            <span>Cosmic Amber</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu button -->
    <button class="mobile-menu-btn" aria-label="Toggle menu" id="mobile-menu-btn">
      <svg class="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div class="mobile-menu" id="mobile-menu">
  <div class="mobile-menu-content">
    <a href={base} class:list={['mobile-nav-link', { active: relativePath === '/' }]}>Home</a>
    <a href="https://blog.frankwkd2026.dpdns.org/" target="_blank" rel="noopener noreferrer" class="mobile-nav-link mobile-external">
      <span>Blog</span>
      <svg class="external-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
        <polyline points="15 3 21 3 21 9"></polyline>
        <line x1="10" y1="14" x2="21" y2="3"></line>
      </svg>
    </a>
    <a href="https://github.com/FrankWkd-Plus?tab=repositories" target="_blank" rel="noopener noreferrer" class="mobile-nav-link mobile-external">
      <span>Projects</span>
      <svg class="external-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
        <polyline points="15 3 21 3 21 9"></polyline>
        <line x1="10" y1="14" x2="21" y2="3"></line>
      </svg>
    </a>
    <a href={`${base}about/`} class:list={['mobile-nav-link', { active: relativePath.startsWith('/about') }]}>About</a>
    <a href="https://github.com/FrankWkd-Plus" target="_blank" rel="noopener noreferrer" class="mobile-nav-link mobile-external">
      <span>GitHub Profile</span>
      <svg class="github-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
      </svg>
    </a>

    <!-- Mobile theme switcher grid -->
    <div class="mobile-theme-grid">
      <button class="mobile-theme-item" data-theme-val="default">Default</button>
      <button class="mobile-theme-item" data-theme-val="cyberpunk">Cyberpunk</button>
      <button class="mobile-theme-item" data-theme-val="aurora">Aurora</button>
      <button class="mobile-theme-item" data-theme-val="amber">Amber</button>
    </div>
  </div>
</div>

<style>
  .nav {
    position: fixed;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 1000;
    padding: 0.9rem 1.5rem;
    
    /* iOS Liquid Glassmorphic Aesthetic */
    background: rgba(255, 255, 255, 0.045);
    backdrop-filter: blur(24px) saturate(200%);
    -webkit-backdrop-filter: blur(24px) saturate(200%);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 1.25rem;
    box-shadow: 
      inset 0 1px 1px 0 rgba(255, 255, 255, 0.3),
      inset 0 -1px 1px 0 rgba(0, 0, 0, 0.25),
      0 16px 40px rgba(0, 0, 0, 0.5);
    animation: slideDown 0.5s ease-out;
  }

  /* 液态玻璃折射高光层 */
  .nav::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1.25rem;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(255, 255, 255, 0.03) 40%,
      transparent 100%
    );
    pointer-events: none;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 4.5vw, 1.25rem);
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.03em;
    color: var(--color-text);
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .logo:hover {
    color: var(--color-primary);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-dim);
    transition: color 0.2s ease, transform 0.2s ease;
    padding: 0.2rem;
    text-decoration: none;
  }

  .github-link:hover {
    color: var(--color-text);
    transform: scale(1.15);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    color: var(--color-text-dim);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    position: relative;
    transition: color 0.2s ease;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    transition: width 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--color-primary);
  }

  .external-icon {
    opacity: 0.7;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .nav-link:hover .external-icon,
  .mobile-external:hover .external-icon {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  /* Solid Labs Icon Theme Switcher (Simplified: No border, no background) */
  .theme-switcher-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .theme-btn {
    background: transparent;
    border: none;
    padding: 0.25rem;
    color: var(--color-text-dim);
    cursor: pointer;
    transition: color 0.2s ease, transform 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .theme-btn:hover {
    color: var(--color-primary);
    transform: scale(1.15);
  }

  .theme-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 180px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition: all 0.2s ease;
    z-index: 1001;
  }

  .theme-menu.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .theme-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.75rem;
    border: none;
    background: transparent;
    color: var(--color-text);
    font-size: 0.85rem;
    border-radius: 0.5rem;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s ease;
  }

  .theme-option:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .dot-default { background: linear-gradient(135deg, #3B82F6, #8B5CF6); }
  .dot-cyberpunk { background: linear-gradient(135deg, #10B981, #06B6D4); }
  .dot-aurora { background: linear-gradient(135deg, #A855F7, #38BDF8); }
  .dot-amber { background: linear-gradient(135deg, #F59E0B, #EF4444); }

  .mobile-theme-grid {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1rem;
  }

  .mobile-theme-item {
    padding: 0.4rem 0.875rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    color: var(--color-text-dim);
    font-size: 0.85rem;
    cursor: pointer;
  }

  .mobile-menu-btn {
    display: none;
    background: transparent;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.5rem;
  }

  .mobile-menu-btn .icon {
    width: 24px;
    height: 24px;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(3, 7, 18, 0.98);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 1.5rem;
  }

  .mobile-nav-link {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mobile-external {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-primary);
  }

  @keyframes slideDown {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media (max-width: 768px) {
    .nav {
      top: 0.75rem;
      left: 0.75rem;
      right: 0.75rem;
      padding: 0.75rem 1rem;
    }

    .nav-links {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }
</style>

<script>
  const setupThemeSwitcher = () => {
    const themeBtn = document.getElementById('theme-btn');
    const themeMenu = document.getElementById('theme-menu');
    const themeOptions = document.querySelectorAll('[data-theme-val]');

    if (themeBtn && themeMenu) {
      themeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        themeMenu.classList.toggle('open');
      });

      document.addEventListener('click', () => {
        themeMenu.classList.remove('open');
      });
    }

    const applyTheme = (val: string) => {
      document.documentElement.setAttribute('data-theme', val);
      localStorage.setItem('darkness_theme_preset', val);
      window.dispatchEvent(new CustomEvent('theme-change', { detail: val }));
    };

    themeOptions.forEach(opt => {
      opt.addEventListener('click', () => {
        const val = opt.getAttribute('data-theme-val');
        if (val) applyTheme(val);
        if (themeMenu) themeMenu.classList.remove('open');
      });
    });
  };

  document.addEventListener('astro:page-load', () => {
    setupThemeSwitcher();
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('open');
      });

      const mobileLinks = mobileMenu.querySelectorAll('.mobile-nav-link');
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
        });
      });
    }
  });
</script>
